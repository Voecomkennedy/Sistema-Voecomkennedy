# Voecomkennedy V2 — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha com os valores reais do projeto Supabase.
# NUNCA commite .env.local ou .env com valores reais.

# URL do projeto Supabase (encontre em: Project Settings > API > Project URL)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima pública do Supabase (encontre em: Project Settings > API > anon public)
# Esta chave é segura para o frontend — o RLS protege os dados.
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# NÃO adicione a service_role_key aqui. Ela é privada e nunca deve ir ao frontend.
